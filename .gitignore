.thumbs.db
node_modules
./node_modules

# Quasar core related directories
.quasar
# Build output — the server builds on deploy, so dist/ is never committed.
/dist
./env
env
# Cordova related directories and files
/src-cordova/node_modules
/src-cordova/platforms
/src-cordova/plugins
/src-cordova/www

# Capacitor related directories and files
/src-capacitor/www
/src-capacitor/node_modules

# BEX related directories and files
/src-bex/www
/src-bex/js/core

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories and files
.idea
*.suo
*.ntvs*
*.njsproj
*.sln

src-capacitor
mykeys.jks
sign_android.bat
stctraining.apk
stctraining.apk.idsig

# Commit yarn only (package-lock causes install drift)
package-lock.json

# Block accidental Finder/OS duplicate files
*.bak
* copy.*
* copy [0-9].*
*_old.*

# macOS Finder metadata (anywhere in the tree)
.DS_Store
**/.DS_Store

# Local AI / coding-assistant tool artifacts — machine-specific, never shared.
# (.claude/ is intentionally NOT ignored — it holds shared project config.)
/skills/
/skills-lock.json
