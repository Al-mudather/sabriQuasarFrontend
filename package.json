{
  "name": "sabri_quasar_frontend",
  "version": "0.0.1",
  "description": "The First Medical Training Platform in Sudan, Africa and the Middle East",
  "productName": "STC | Medical Training Platform",
  "author": "Alhasif International Company <https://alhasif.com>",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js,.vue ./",
    "dev": "quasar dev",
    "build": "quasar build",
    "test": "echo \"See package.json => scripts for available tests.\" && exit 0",
    "test:just": "quasar test --unit jest",
    "test:unit": "jest --updateSnapshot",
    "test:unit:ci": "jest --ci",
    "test:unit:coverage": "jest --coverage",
    "test:unit:watch": "jest --watch",
    "test:unit:watchAll": "jest --watchAll",
    "serve:test:coverage": "quasar serve test/jest/coverage/lcov-report/ --port 8788",
    "concurrently:dev:jest": "concurrently \"quasar dev\" \"jest --watch\"",
    "test:e2e": "cross-env E2E_TEST=true start-test \"quasar dev\" http-get://localhost:8080 \"cypress open\"",
    "test:e2e:ci": "cross-env E2E_TEST=true start-test \"quasar dev\" http-get://localhost:8080 \"cypress run\"",
    "codegen": "graphql-codegen --config codegen.yml",
    "codegen:check": "graphql-codegen --config codegen.yml --check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:vue": "vue-tsc --noEmit -p tsconfig.vue.json"
  },
  "dependencies": {
    "@apollo/client": "^3.9.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@lifeomic/axios-fetch": "^1.5.1",
    "@quasar/extras": "^1.16.0",
    "@unhead/vue": "^1.9.0",
    "@vimeo/player": "^2.30.3",
    "@vue/apollo-composable": "^4.0.0",
    "apollo-upload-client": "^18.0.1",
    "axios": "^0.21.1",
    "core-js": "^3.8.3",
    "dompurify": "^3.4.1",
    "dotenv": "^8.2.0",
    "graphql": "^16.8.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^5.16.0",
    "gsap": "^3.12.5",
    "jquery": "^3.3.1",
    "js-cookie": "^3.0.5",
    "js-file-download": "^0.4.12",
    "lodash": "^4.17.21",
    "logrocket": "^2.1.2",
    "marked": "^18.0.2",
    "moment": "^2.29.1",
    "mux.js": "^5.11.1",
    "node-fetch": "^2.6.1",
    "pinia": "^2.1.0",
    "pinia-plugin-persistedstate": "^3.2.0",
    "quasar": "^2.14.0",
    "swiper": "^11.0.0",
    "video.js": "^8.23.7",
    "videojs-contrib-eme": "^5.5.2",
    "videojs-contrib-quality-levels": "^4.1.0",
    "videojs-hls-quality-selector": "^2.0.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.9.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typed-document-node": "^6.1.8",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@quasar/app-vite": "^1.8.0",
    "@types/dompurify": "^3.0.5",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.5.0",
    "babel-eslint": "^10.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-cypress": "^2.11.1",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jest": "^27.0.0",
    "eslint-plugin-node": "^11.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "full-icu": "^1.3.4",
    "postcss": "^8.5.10",
    "request-promise": "^4.2.6",
    "typescript": "^5.3.0",
    "vue-jest": "^5.0.0-alpha.10",
    "vue-tsc": "^2.1.10"
  },
  "browserslist": [
    "last 10 Chrome versions",
